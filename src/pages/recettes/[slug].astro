---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import RecipeInteractions from '../../components/RecipeInteractions.tsx';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const recipes = await getCollection('recettes');
  return recipes.map(r => ({ params: { slug: r.id }, props: { recipe: r } }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const { title, description, date, tags, photo, meta } = recipe.data;

// Get all recipes for prev/next navigation
const allRecipes = (await getCollection('recettes')).sort((a, b) => {
  const da = new Date(a.data.date.split(' ').reverse().join('-'));
  const db = new Date(b.data.date.split(' ').reverse().join('-'));
  return db.getTime() - da.getTime();
});
const currentIdx = allRecipes.findIndex(r => r.id === recipe.id);
const prev = currentIdx < allRecipes.length - 1 ? allRecipes[currentIdx + 1] : null;
const next = currentIdx > 0 ? allRecipes[currentIdx - 1] : null;

---

<BaseLayout title={title} description={description} photo={photo}>
  <Nav showBack />

  <div class="recipe-layout" id="recipe-layout">
    <main class="content-col">
      <div class="recipe-tags">
        {tags.map(t => (
          <a href={`/?tag=${t.toLowerCase()}`} class="tag">{t}</a>
        ))}
      </div>

      <h1 class="recipe-title">{title}</h1>
      <p class="recipe-desc">{description}</p>

      {photo && (
        <img src={photo} alt={title} class="photo-mobile" />
      )}

      {meta && Object.values(meta).some(v => v) && (
        <div class="meta-strip">
          {meta.portions && (
            <div class="meta-item">
              <span class="meta-label">Portions</span>
              <span class="meta-value">{meta.portions}</span>
            </div>
          )}
          {meta.prep && (
            <div class="meta-item">
              <span class="meta-label">Préparation</span>
              <span class="meta-value">{meta.prep}</span>
            </div>
          )}
          {meta.cuisson && (
            <div class="meta-item">
              <span class="meta-label">Cuisson</span>
              <span class="meta-value">{meta.cuisson}</span>
            </div>
          )}
          {meta.repos && (
            <div class="meta-item">
              <span class="meta-label">Repos</span>
              <span class="meta-value">{meta.repos}</span>
            </div>
          )}
        </div>
      )}

      <!-- Hidden raw content for parsing by React component -->
      <div id="recipe-content" style="display:none">
        <Content />
      </div>

      <RecipeInteractions client:load />

      <div class="content-footer">
        <span class="recipe-date">{date}</span>
        <div class="nav-links">
          {prev && <a href={`/recettes/${prev.id}/`} class="nav-link">← {prev.data.title}</a>}
          {next && <a href={`/recettes/${next.id}/`} class="nav-link">{next.data.title} →</a>}
        </div>
      </div>
    </main>

    <aside class="photo-col">
      {photo ? (
        <div style="position:relative; width:100%; height:100%">
          <img src={photo} alt={title} class="photo-img" onload="this.classList.add('visible')" />
          <span class="photo-caption">{title}</span>
        </div>
      ) : (
        <div class="photo-placeholder">
          <span class="placeholder-initial">{title.charAt(0)}</span>
        </div>
      )}
    </aside>
  </div>
</BaseLayout>


<style>
  .recipe-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 1rem; }
  .tag {
    font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 2px 9px; background: var(--accent-pale); color: var(--accent);
    font-weight: 500; text-decoration: none; transition: background 0.2s, color 0.2s;
  }
  .tag:hover { background: var(--accent); color: #fff; }

  .recipe-title {
    font-family: var(--serif); font-weight: 300;
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    line-height: 1.05; letter-spacing: -0.015em;
    margin-bottom: 0.85rem;
  }
  .recipe-desc { font-size: 0.9rem; line-height: 1.7; color: var(--ink-light); margin-bottom: 2rem; }

  .photo-mobile {
    display: none;
    width: 100%; aspect-ratio: 2/3; object-fit: cover; object-position: center;
    margin-bottom: 2rem; background: #1a1a18;
  }
  @media (max-width: 780px) { .photo-mobile { display: block; } }

  .meta-strip {
    display: flex; flex-wrap: wrap;
    border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .meta-item {
    padding: 0.75rem 1.25rem 0.75rem 0; margin-right: 1.25rem;
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 2px;
  }
  .meta-item:last-child { border-right: none; }
  .meta-label { font-size: 0.63rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-light); font-weight: 500; }
  .meta-value { font-family: var(--serif); font-size: 1.05rem; color: var(--ink); }

  /* Recipe interactions styles (global for the React island) */
  :global(.progress-bar) {
    position: fixed; top: 0; left: 0; height: 2px; z-index: 100;
    background: var(--accent); transition: width 0.1s linear;
  }

  :global(.section-label) {
    font-size: 0.63rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ink-light); font-weight: 500; margin-bottom: 1rem;
  }
  :global(.ingredients-list) { list-style: none; margin-bottom: 2.5rem; }
  :global(.ingredient-item) {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 9px 0; border-bottom: 1px solid var(--border); cursor: pointer;
    transition: opacity 0.2s; -webkit-tap-highlight-color: transparent;
  }
  :global(.ingredient-item:first-child) { border-top: 1px solid var(--border); }
  :global(.ingredient-item.checked) { opacity: 0.35; }
  :global(.ingredient-check) {
    width: 17px; height: 17px; flex-shrink: 0; margin-top: 2px;
    border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, border-color 0.2s;
  }
  :global(.ingredient-item.checked .ingredient-check) { background: var(--accent); border-color: var(--accent); }
  :global(.check-icon) { color: white; font-size: 10px; }
  :global(.ingredient-qty) { font-size: 0.75rem; font-weight: 500; color: var(--accent); display: block; margin-bottom: 1px; }
  :global(.ingredient-label) { font-size: 0.9rem; line-height: 1.4; }
  :global(.ingredient-item.checked .ingredient-label) { text-decoration: line-through; text-decoration-color: var(--ink-light); }
  :global(.cooking-hint) { font-size: 0.7rem; color: var(--ink-xlight); font-style: italic; margin-top: 0.75rem; }

  :global(.steps-list) { list-style: none; display: flex; flex-direction: column; gap: 1.75rem; margin-bottom: 3rem; }
  :global(.step-item) { display: grid; grid-template-columns: 2.25rem 1fr; gap: 1rem; cursor: pointer; -webkit-tap-highlight-color: transparent; }
  :global(.step-num) {
    font-family: var(--serif); font-weight: 200; font-size: 2rem;
    line-height: 1; color: var(--border); transition: color 0.3s; user-select: none; padding-top: 3px;
  }
  :global(.step-item:hover .step-num), :global(.step-item.done .step-num) { color: var(--accent); }
  :global(.step-item.done .step-content) { opacity: 0.4; }
  :global(.step-content) { transition: opacity 0.3s; }
  :global(.step-title) {
    font-family: var(--serif); font-weight: 400; font-size: 1rem;
    margin-bottom: 0.3rem; display: flex; align-items: center; gap: 8px;
  }
  :global(.done-badge) {
    font-family: var(--sans); font-size: 0.6rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--accent); opacity: 0; transition: opacity 0.3s;
  }
  :global(.step-item.done .done-badge) { opacity: 1; }
  :global(.step-text) { font-size: 0.87rem; line-height: 1.72; color: var(--ink-light); }

  .content-footer {
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 1rem;
    padding-top: 2rem; border-top: 1px solid var(--border);
  }
  .recipe-date { font-family: var(--serif); font-style: italic; font-size: 0.78rem; color: var(--ink-xlight); }
  .nav-links { display: flex; gap: 1.5rem; }
  .nav-link { font-size: 0.78rem; color: var(--ink-light); text-decoration: none; transition: color 0.2s; }
  .nav-link:hover { color: var(--accent); }

  /* Layout */
  .recipe-layout {
    display: grid;
    grid-template-columns: 1fr 400px;
    min-height: calc(100vh - 52px);
  }
  @media (max-width: 780px) {
    .recipe-layout { grid-template-columns: 1fr; display: block; }
  }

  .content-col {
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1.5rem, 4vw, 3.5rem);
    max-width: 560px;
  }
  @media (max-width: 780px) { .content-col { max-width: 100%; } }

  .photo-col {
    position: sticky; top: 52px;
    height: calc(100vh - 52px);
    overflow: hidden;
    background: var(--dark);
  }
  @media (max-width: 780px) { .photo-col { display: none; } }

  .photo-img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    opacity: 0; transition: opacity 0.6s ease;
    display: block;
  }
  :global(.photo-img.visible) { opacity: 1; }

  .photo-placeholder {
    width: 100%; height: 100%;
    background: var(--dark);
    display: flex; align-items: center; justify-content: center;
  }
  .placeholder-initial {
    font-family: var(--serif); font-style: italic; font-weight: 200;
    font-size: 8rem; color: rgba(255,255,255,0.06); user-select: none;
    line-height: 1;
  }

  .photo-caption {
    position: absolute; bottom: 1.25rem; left: 1.25rem;
    font-size: 0.65rem; color: rgba(255,255,255,0.35);
    letter-spacing: 0.08em; text-transform: uppercase; font-family: var(--sans);
  }
</style>
