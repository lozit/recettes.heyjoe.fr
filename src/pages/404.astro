---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Page introuvable">
  <Nav showBack />
  <main class="not-found">
    <p class="not-found-code">404</p>
    <p class="not-found-text">Cette recette n'existe pas (encore).</p>
    <a href="/" class="not-found-link">← Retour aux recettes</a>
  </main>
</BaseLayout>

<style>
  .not-found {
    max-width: var(--col); margin: 0 auto;
    padding: 8rem clamp(1rem, 4vw, 2rem);
    text-align: center;
  }
  .not-found-code {
    font-family: var(--serif); font-weight: 200;
    font-size: 5rem; color: var(--border); line-height: 1; margin-bottom: 1rem;
  }
  .not-found-text {
    font-family: var(--serif); font-style: italic;
    font-size: 1.1rem; color: var(--ink-light); margin-bottom: 2rem;
  }
  .not-found-link {
    font-size: 0.85rem; color: var(--accent); text-decoration: none;
    transition: opacity 0.2s;
  }
  .not-found-link:hover { opacity: 0.7; }
</style>
